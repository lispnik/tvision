[18.26435089111328, "o", "se\u001b[0;37;44m.\u001b[18;3H\u001b[0;97;44mDescription:\u001b[0;37;44m \u001b[18;17H  \u001b[18;20H     \u001b[18;26H  \u001b[18;29H                  \u001b[18;48H            \u001b[18;61H   \u001b[18;65H \u001b[18;67H          \u001b[20;3HTests whether\u001b[20;17H\u001b[0;97;44mchar \u001b[0;37;44mis\u001b[20;25Ha\u001b[20;27Hdigit\u001b[20;33Hin\u001b[20;36Hthe\u001b[20;40Hspecified\u001b[20;50H\u001b[0;97;44mradix \u001b[0;37;44m(i.e.,\u001b[20;63Hwith\u001b[20;68Ha\u001b[20;70Hweight\u001b[20;77Hless\u001b[20;82Hthan\u001b[21;3H\u001b[0;97;44mradix\u001b[0;37;44m).\u001b[21;11HIf\u001b[21;14Hit\u001b[21;17His\u001b[21;20Ha\u001b[21;22Hdigit\u001b[21;28Hin\u001b[21;31Hthat\u001b[21;36H\u001b[0;97;44mradix\u001b[0;37;44m,\u001b[21;43Hits\u001b[21;47Hweight\u001b[21;54His\u001b[21;57Hreturned\u001b[21;66Has\u001b[21;69Han\u001b[21;72H\u001b[0;95;44minteger\u001b[0;37;44m;\u001b[22;3Hotherwise \u001b[0;95;44mnil\u001b[22;17H\u001b[0;37;44mis returned.           \u001b[22;41H                                 \u001b[23;3H                               \u001b[24;3H\u001b[0;97;44mExamples:\u001b[25;3H\u001b[0;37;44m            \u001b[27;3H\u001b[0;92;44m (digit-char-p #\\5)    =>  5\u001b[0;37;44m                                                        \u001b[28;3H\u001b[0;92;44m (digit-char-p #\\5 2)  =>  false\u001b[0;37;44m                "]
