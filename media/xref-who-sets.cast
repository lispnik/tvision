[12.069094896316528, "o", "tf (event-type e) +ev-command+ (event-command e) cmd (event-info e) ni\u001b[0;38;5;248;48;5;19m\u2592\u001b[0;38;5;239;48;5;16m  \u001b[8;3H\u001b[0;38;5;231;48;5;19m\u2551\u001b[0;38;5;239;48;5;19m202\u001b[0;38;5;231;48;5;19m                                                                             \u001b[0;38;5;248;48;5;19m\u2592\u001b[0;38;5;239;48;5;16m  \u001b[9;3H\u001b[0;38;5;231;48;5;19m\u2551\u001b[0;38;5;239;48;5;19m203\u001b[0;38;5;231;48;5;19m  (defun current-help-ctx (app)                                              \u001b[0;38;5;248;48;5;19m\u2592\u001b[0;38;5;239;48;5;16m  \u001b[10;3H\u001b[0;38;5;231;48;5;19m\u2551\u001b[0;38;5;239;48;5;19m204\u001b[0;38;5;231;48;5;19m    \u001b[0;38;5;124;48;5;19m\"The nearest non-zero help context along the focused chain (so a window's\u001b[0;38;5;248;48;5;19m\u2592\u001b[0;38;5;239;48;5;16m  \u001b[11;3H\u001b[0;38;5;231;48;5;19m\u2551\u001b[0;38;5;239;48;5;19m205\u001b[0;38;5;231;48;5;19m  \u001b[0;38;5;124;48;5;19mcontext applies to its controls, which usually leave help-ctx at 0).\"\u001b[0;38;5;231;48;5;19m      \u001b[0;38;5;248;48;5;19m\u2592\u001b[0;38;5;239;48;5;16m  \u001b[12;3H\u001b[0;38;5;231;48;5;19m\u2551\u001b[0;38;5;239;48"]
